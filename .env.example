# Drizzle
DATABASE_URL=file:local.db

ORIGIN=""

# Better Auth
# For production use 32 characters and generated with high entropy
# https://www.better-auth.com/docs/installation
BETTER_AUTH_SECRET=""

# ---------------------------------------------------------------------------
# libSQL / Turso auth token — required when DATABASE_URL is a remote libsql://
# URL (unused for a local file: database).
# ---------------------------------------------------------------------------
DATABASE_AUTH_TOKEN=""

# ---------------------------------------------------------------------------
# Sync worker (worker/) — a standalone `bun run worker` process. It reads the
# same DATABASE_URL / DATABASE_AUTH_TOKEN above, plus:
# ---------------------------------------------------------------------------
# Content-addressed blob storage. Crawls always write new bodies to the local
# cache dir; R2 (the canonical archive) is written through only when the worker
# runs with --publish (a CLI flag, not an env var — prod passes it). `blob.
# r2_synced_at` marks objects confirmed in R2. `blobs:push` promotes held blobs.
# BLOB_DIR=.cache/blobs        # local cache location (dev/testing, no egress cost)

# Cloudflare R2 (S3-compatible) — remote persistence. Also used by the
# `blobs:push|pull|sync` scripts to move the local cache to/from R2.
R2_ENDPOINT=""          # https://<accountid>.r2.cloudflarestorage.com
R2_BUCKET=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""

# Optional crawl tuning (sensible defaults in worker/config.ts)
# CRAWLER_USER_AGENT="OCS/1.0 (contact: you@example.org)"
# CRAWLER_RATE_LIMIT=1.0          # base seconds between requests (politeness)
# CRAWLER_RATE_LIMIT_JITTER=0     # + random 0..N s, so pacing isn't perfectly periodic
# CRAWLER_MAX_PAGES=20000         # hard safety cap per run
# CRAWLER_MAX_DOC_BYTES=      # skip downloading docs (PDF/Office) larger than N bytes;
#                             # HTML is always fetched. 0 = skip all docs (pages-only).
#                             # (Per-run override: the dashboard's "Max file size, MB".)
# CRAWLER_SEEDS=              # comma-separated paths/URLs to override the default seeds
#
# sync-mode freshness (per-tier TTL in days; a URL is only re-fetched once stale)
# CRAWLER_TTL_CORE_DAYS=7     # core sitemap pages
# CRAWLER_TTL_PAGE_DAYS=7     # other pages
# CRAWLER_TTL_AGENDA_DAYS=30  # agenda/minutes PDFs
# CRAWLER_TTL_DOC_DAYS=180    # DocumentCenter PDFs (near-immutable)
# CRAWLER_SYNC_BATCH=200      # due-resources claimed per batch
# CRAWLER_ERROR_BACKOFF_HOURS=6  # re-schedule delay for a failed URL
#
# Auto-schedule: an idle worker enqueues a `sync` run this often (0 = disabled,
# manual/dashboard runs only). Crashed runs are reaped after WORKER_STALE_MINUTES.
# SYNC_SCHEDULE_MINUTES=60
# WORKER_STALE_MINUTES=5

# ---------------------------------------------------------------------------
# RAG embedding pipeline (`bun run worker:embed`, mode = embed). Splits the
# extracted text into chunks and embeds them into libSQL-native vectors. The
# model is chosen here and swapped without code changes (worker/embeddings.ts).
# ---------------------------------------------------------------------------
# Provider: cloudflare | openai | fake. Unset = auto-detect from the credentials
# below, falling back to the deterministic offline 'fake' embedder (CI / no keys).
# EMBEDDING_PROVIDER=cloudflare
# Cloudflare Workers AI (default model @cf/baai/bge-base-en-v1.5, 768-dim):
# CLOUDFLARE_ACCOUNT_ID=""
# CLOUDFLARE_API_TOKEN=""
# CLOUDFLARE_EMBED_MODEL="@cf/baai/bge-base-en-v1.5"
# OpenAI (default model text-embedding-3-small, requested at 768 dims):
# OPENAI_API_KEY=""
# OPENAI_EMBED_MODEL="text-embedding-3-small"
# Chunking / batching knobs (sensible defaults in worker/config.ts):
# EMBED_CHUNK_CHARS=1200      # target chunk size in characters
# EMBED_CHUNK_OVERLAP=200     # overlap between neighbouring chunks
# EMBED_BATCH=32              # chunks per embedding request
