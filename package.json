{
	"name": "orleans",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"engines": {
		"node": "24.x"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo '' && husky",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run && npm run test:e2e",
		"test:e2e": "playwright install && playwright test",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build",
		"db:push": "drizzle-kit push",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:studio": "drizzle-kit studio",
		"worker": "bun run worker/index.ts",
		"worker:estimate": "bun run worker/index.ts --mode estimate --once",
		"worker:extract": "bun run worker/index.ts --mode extract --once",
		"worker:embed": "bun run worker/index.ts --mode embed --once",
		"blobs:sync": "bun run worker/sync-blobs.ts --both",
		"blobs:push": "bun run worker/sync-blobs.ts --push",
		"blobs:pull": "bun run worker/sync-blobs.ts --pull",
		"auth:schema": "better-auth generate --config src/lib/server/auth.ts --output src/lib/server/db/auth.schema.ts --yes"
	},
	"devDependencies": {
		"@better-auth/cli": "~1.4.21",
		"@chromatic-com/storybook": "^5.2.1",
		"@eslint/js": "^10.0.1",
		"@fontsource-variable/inter": "^5.2.8",
		"@inlang/paraglide-js": "^2.18.2",
		"@internationalized/date": "^3.12.0",
		"@libsql/client": "^0.17.3",
		"@lucide/svelte": "^1.24.0",
		"@playwright/test": "^1.60.0",
		"@storybook/addon-a11y": "^10.5.0",
		"@storybook/addon-docs": "^10.5.0",
		"@storybook/addon-svelte-csf": "^5.1.2",
		"@storybook/addon-vitest": "^10.5.0",
		"@storybook/sveltekit": "^10.5.0",
		"@sveltejs/adapter-cloudflare": "^8.0.0-next.2",
		"@sveltejs/adapter-vercel": "^7.0.0-next.2",
		"@sveltejs/kit": "next",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@tailwindcss/vite": "^4.3.0",
		"@tanstack/table-core": "^8.21.3",
		"@types/node": "^22",
		"@vitest/browser-playwright": "^4.1.8",
		"@vitest/coverage-v8": "^4.1.8",
		"better-auth": "~1.4.21",
		"bits-ui": "^2.16.3",
		"clsx": "^2.1.1",
		"drizzle-kit": "^0.31.10",
		"drizzle-orm": "^0.45.2",
		"embla-carousel-svelte": "^8.6.0",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-storybook": "^10.5.0",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"layerchart": "2.0.0-next.48",
		"lint-staged": "^17.0.8",
		"mode-watcher": "^1.1.0",
		"paneforge": "^1.0.2",
		"playwright": "^1.60.0",
		"prettier": "^3.8.3",
		"prettier-plugin-svelte": "^4.1.0",
		"prettier-plugin-tailwindcss": "^0.8.0",
		"shadcn-svelte": "^1.4.1",
		"storybook": "^10.5.0",
		"svelte": "^5.56.1",
		"svelte-check": "^4.6.0",
		"svelte-sonner": "^1.1.0",
		"tailwind-merge": "^3.6.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.3.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.60.1",
		"vaul-svelte": "^1.0.0-next.7",
		"vite": "^8.0.16",
		"vitest": "^4.1.8",
		"vitest-browser-svelte": "^2.1.1",
		"wrangler": "^4.111.0"
	},
	"lint-staged": {
		"*.{js,ts,svelte,json,css,md,html}": "prettier --write --ignore-unknown",
		"*.{js,ts,svelte}": "eslint --fix"
	},
	"dependencies": {
		"@anthropic-ai/sdk": "^0.112.1",
		"@mozilla/readability": "^0.6.0",
		"aws4fetch": "^1.0.20",
		"linkedom": "^0.18.13",
		"unpdf": "^1.6.2"
	}
}
